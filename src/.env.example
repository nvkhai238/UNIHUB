# ============================================================
# UniHub Workshop — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit .env vào git
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Lấy từ: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lấy từ: Supabase Dashboard > Settings > Database > Connection string (URI)
SUPABASE_DB_URL=jdbc:postgresql://db.your-project.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# ── JWT ───────────────────────────────────────────────────
# Chuỗi ngẫu nhiên >= 32 ký tự
# Sinh bằng: openssl rand -base64 64
JWT_SECRET=replace-with-a-very-long-random-secret-string-at-least-32-chars

# ── Gemini AI ─────────────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── SMTP Email ────────────────────────────────────────────
# Dùng Gmail App Password hoặc Mailtrap (sandbox) khi dev
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
